{
  "extends": "@codax/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@codax/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/ui/src/components/**/*.tsx",
    "../../packages/ui/src/components/ui/tag.tsx",
    "../../packages/ui/src/components/ui/sectionHeader.tsx",
    "../../packages/ui/src/lib/getIcon.ts"
  ],
  "exclude": ["node_modules"]
}
